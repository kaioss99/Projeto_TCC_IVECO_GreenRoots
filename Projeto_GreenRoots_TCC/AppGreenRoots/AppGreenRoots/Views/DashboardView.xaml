<Window x:Class="AppGreenRoots.Views.DashboardView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AppGreenRoots" Width="900" Height="560"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize" WindowStyle="None"
        AllowsTransparency="True" Background="Transparent">

    <Window.Resources>
        <SolidColorBrush x:Key="BgDark"   Color="#0D1A12"/>
        <SolidColorBrush x:Key="BgCard"   Color="#13261A"/>
        <SolidColorBrush x:Key="Green"    Color="#2ECC71"/>
        <SolidColorBrush x:Key="White"    Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextMuted" Color="#A0B8A8"/>
        <SolidColorBrush x:Key="BorderClr" Color="#2A5038"/>

        <Style x:Key="BtnSair" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#A0B8A8"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="Height"          Value="30"/>
            <Setter Property="Width"           Value="60"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="6"
                                BorderBrush="#2A5038" BorderThickness="1"
                                Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource Green}"/>
                                <Setter Property="Foreground" Value="{StaticResource Green}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="12" Background="{StaticResource BgDark}">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="0" Color="#000000" Opacity="0.5"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="56"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Barra superior -->
            <Border Grid.Row="0" Background="{StaticResource BgCard}"
                    CornerRadius="12,12,0,0"
                    BorderBrush="{StaticResource BorderClr}" BorderThickness="0,0,0,1">
                <Grid Margin="20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Nome do app -->
                    <TextBlock Grid.Column="0" Text="AppGreenRoots"
                               FontSize="14" FontWeight="Bold" FontFamily="Segoe UI"
                               Foreground="{StaticResource Green}"
                               VerticalAlignment="Center"/>

                    <!-- Saudação -->
                    <TextBlock Grid.Column="1" FontSize="13" FontFamily="Segoe UI"
                               Foreground="{StaticResource TextMuted}"
                               HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Run Text="Bem-vindo, "/>
                        <Run Text="{Binding NomeUsuario, Mode=OneWay}"
                             Foreground="{StaticResource White}" FontWeight="SemiBold"/>
                    </TextBlock>

                    <!-- Sair + Fechar -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="Sair" Style="{StaticResource BtnSair}"
                                Command="{Binding LogoutCommand}" Margin="0,0,8,0"/>
                        <Button Content="✕" Width="24" Height="24" FontSize="11"
                                Foreground="{StaticResource TextMuted}" Background="Transparent"
                                BorderThickness="0" Cursor="Hand" Click="BtnFechar_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Conteúdo -->
            <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Dashboard de Sensores"
                           FontSize="22" FontWeight="Bold" FontFamily="Segoe UI"
                           Foreground="{StaticResource White}"
                           HorizontalAlignment="Center" Margin="0,0,0,10"/>
                <TextBlock Text="A leitura do Arduino será exibida aqui em breve."
                           FontSize="13" FontFamily="Segoe UI"
                           Foreground="{StaticResource TextMuted}"
                           HorizontalAlignment="Center"/>
            </StackPanel>

        </Grid>
    </Border>
</Window>
